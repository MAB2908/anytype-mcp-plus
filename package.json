{
  "name": "anytype-mcp-plus",
  "version": "1.1.0",
  "type": "module",
  "description": "Enhanced MCP server for Anytype — 34 tools for full CRUD on spaces, objects, types, properties, tags, templates, collections, and global search. Fork of cryptonahue/mcp-anytype with bug fixes and new capabilities.",
  "author": "MAB2908",
  "license": "MIT",
  "homepage": "https://github.com/MAB2908/anytype-mcp-plus#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/MAB2908/anytype-mcp-plus.git"
  },
  "bugs": {
    "url": "https://github.com/MAB2908/anytype-mcp-plus/issues"
  },
  "keywords": [
    "anytype",
    "mcp",
    "model-context-protocol",
    "anytype-api",
    "claude",
    "ai",
    "automation",
    "knowledge-management",
    "pkm",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "dotenv": "^16.4.7",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
