# anytype-mcp-plus configuration
# Copy this file to .env and fill in your values

# Required: Anytype API key
# Get it from: Anytype Desktop App → Settings → API → Create API Key
ANYTYPE_API_KEY=your-api-key-here

# Optional: Anytype API base URL (default: http://localhost:31009)
# Change only if your Anytype instance runs on a different port
ANYTYPE_BASE_URL=http://localhost:31009
